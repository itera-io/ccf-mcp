# Cloudera Cloud Factory MCP Server Environment Variables
# Copy this file to .env and update with your actual values

# Cloudera Cloud Factory API Configuration (legacy TAIKUN_* names)
# Robot User authentication
TAIKUN_ACCESS_KEY=your-robot-user-access-key-here
TAIKUN_SECRET_KEY=your-robot-user-secret-key-here
TAIKUN_API_HOST=api-latest.osc1.sjc.cloudera.com

# Optional: set this only if your environment requires an explicit domain name
# TAIKUN_DOMAIN_NAME=your-domain-name
